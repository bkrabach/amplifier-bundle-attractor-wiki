// wiki-ingest-unified pipeline — generalized 1..N batch; N=1 reduces cleanly to single-file behavior.
//
// Runs under the wiki-agent-anthropic child profile. The LOAD-BEARING schema/scripts
// are project-side in .wiki/ and reached by the box nodes' filesystem tools.
//
// Node-type discipline (attractor conventions):
//   parallelogram = deterministic shell (route on EXIT CODE, never LLM text)
//   box (default) = LLM agent node (judgment / content generation)
//   diamond       = pure router
//
// Pipeline phases (in order):
//   classify → mine → write_pages → verify → reconcile → provenance_audit → enforce_attribution → weave → update_spine → review → verify2 → archive
//
// FAIL-CLOSED INPUT GUARD (classify node):
//   The classify node runs .wiki/scripts/classify_source.py on the source file BEFORE
//   any LLM work.  It binary-sniffs first (NUL bytes / UTF-8 failure → reject) then
//   checks extension (code → reject, prose → accept).  FAIL CLOSED: missing script,
//   crashed helper, or any fault → last_line != CLASSIFY_OK → classify_gate routes to
//   done WITHOUT reaching mine.  There is NO path from a non-accept to mine.
//
// L3 PERFORMANCE TRADEOFF (honest, not a fidelity virtue): reconcile,
// provenance_audit, weave, and review are all SCOPED to the changed-page
// neighborhood for speed. This deliberately accepts that global semantic
// consistency — cross-ingest duplicate detection, whole-wiki provenance, the
// full connections graph — degrades between runs. Karpathy's pattern calls for
// the LLM to scan the whole graph each pass; we DEFER that to a periodic /lint
// or full-pass run to keep unattended ingest affordable. SCOPED ≠ SURGICAL.
//
// WEAVE is the Memex connections layer: generates new grounded associative
// trails between distinct, already-correct pages — connections no source stated
// but genuinely implied by claims already on the pages. Spike-proven on the
// real 33-page wiki: 8/10 grounded non-obvious connections, 0 hallucinations.
// This is the difference between a filing cabinet and a compounding knowledge base.

digraph WikiIngest {
    graph [
        goal="Batch-ingest all source files currently in raw/ into the wiki per .wiki/context/schema.md",
        default_max_retry=3,
        default_fidelity="full",
        default_thread_id="wiki-ingest-unified"
    ]

    start [shape=Mdiamond]
    done  [shape=Msquare]

    // Step 1 — Orient (deterministic): is the project initialized + is there a source?
    orient [
        shape=parallelogram,
        tool_command="test -f .wiki/context/schema.md && ls raw/ >/dev/null 2>&1 && printf ready || printf uninitialized"
    ]

    // Step 1b — FAIL-CLOSED INPUT GUARD (deterministic, no LLM).
    // Runs .wiki/scripts/classify_source.py on the source BEFORE any LLM work.
    // Binary-sniffs first (NUL bytes / UTF-8 failure → REJECT regardless of extension).
    // Then checks extension: code → REJECT; prose → ACCEPT; ambiguous → ACCEPT.
    // FAIL CLOSED: missing script, crashed helper, or any fault causes python3 to exit
    // nonzero, which makes the shell append CLASSIFY_REJECTED as the last line, routing
    // to done. There is NO path from a non-accept to mine.
    // The full actionable message (from classify_source.py stdout) appears in the node
    // log before the routing sentinel — visible to the operator on reject.
    classify [
        shape=parallelogram,
        tool_command="STATUS=0; FOUND=0; for f in raw/*.md raw/*.txt raw/*.rst; do [ -f \"$f\" ] || continue; FOUND=1; python3 .wiki/scripts/classify_source.py \"$f\" >/tmp/wiki-classify-batch.out 2>&1; RC=$?; cat /tmp/wiki-classify-batch.out; [ $RC -ne 0 ] && { echo \"BATCH_REJECT: $f\"; STATUS=1; }; done; [ $FOUND -eq 0 ] && { echo 'BATCH_REJECT: no source files found in raw/'; STATUS=1; }; [ $STATUS -eq 0 ] && echo CLASSIFY_OK || echo CLASSIFY_REJECTED"
    ]
    classify_gate [shape=diamond]

    // Step 2 — Mine the source (LLM): extract per schema, write a concrete ingest plan.
    mine [
        llm_provider="anthropic",
        prompt="You are running /wiki-ingest as an automated pipeline (no interactive mode, no human in the loop). The load-bearing contract is .wiki/context/schema.md; your mounted orientation explains the pattern to read it through.\n\nBATCH MODE: Read ALL source files currently in raw/ (list them with: ls raw/*.md raw/*.txt 2>/dev/null — every file except those under raw/archive/). Read each one fully.\n\nSINGLE VS MULTIPLE SOURCES: Count how many source files are present in raw/ before proceeding.\n- If exactly ONE source file is present: mine it exactly as you would in a standard single-file ingest — extract entities, concepts, decisions, and cross-refs from that one source. Do NOT fabricate self-contradictions, phantom cross-references, or spurious cross-source agreements/disagreements. There is only one source; act accordingly.\n- If MULTIPLE sources are present: mine all sources COLLECTIVELY and ALSO actively look for cross-source agreements and contradictions — e.g. two sources both mentioning the same person/outcome, or conflicting claims about a decision. Capture these genuine cross-source relationships in the ingest-plan.\n\nMine the source(s) per the schema (entities, concepts, decisions, cross-refs from ALL sources). IMPORTANT: first read the EXISTING pages under team-knowledge/ (outcomes, concepts, people, sources) and reuse an existing entity page when the source refers to the same thing under a different name — do not invent a new slug for an entity that already exists.\n\nSETTLED-WRITE-LOCK (non-negotiable): Before writing the ingest plan, for each existing page the source would touch, read its frontmatter and check the status field. If ANY page has status: settled AND the new source contradicts or reverses that page's primary load-bearing claim: (1) DO NOT plan to overwrite or replace the settled claim — it is write-locked against silent overwrite; (2) PRESERVE the original settled claim verbatim in the page body; (3) ADD an explicit READER-VISIBLE tension entry to team-knowledge/open-questions.md under the ## Tensions or ## Contradictions section — NOT a hidden HTML comment — naming both the settled claim (with its source slug and date) and the contradicting claim (with its source slug and date); (4) DOWNGRADE the page status from settled to working in the plan — a contested claim is no longer settled; (5) NEVER silently relabel the new content as settled. If the source agrees with the settled claim, no lock applies. This rule applies even when the new source is dated later — settled status is a human-confirmed write lock, not a timestamp race. Auto-resolving a settled conflict internally without surfacing it is a pipeline faithfulness failure.\n\nWrite ONE unified ingest-plan to .wiki/ingest-plan.md covering ALL pages to create or update across the entire batch. For each page: name every specific edit AND list which source file(s) the content comes from (so write_pages can cite each source correctly — sources[] on each page should list ONLY the sources that actually contributed content to THAT page, not all batch sources). Each source file in raw/ gets its own sources/ page.\n\nDo not write wiki pages yet. End with a one-line summary; your final message MUST be non-empty plain text."
    ]

    // Step 3 — Apply the plan (LLM): create/edit pages, update index + log, cite.
    // No goal_gate: the deterministic verify.sh loop below IS the real gate.
    write_pages [
        llm_provider="anthropic",
        prompt="Apply .wiki/ingest-plan.md against the wiki package: create/edit each page following the schema's frontmatter + body conventions, wire [[wikilinks]] and sources[], update index.md, and append one line to log.md. Cite every claim to a source page. Honor the status discipline (settled / working / unsettled; proposals are NOT decisions; never fabricate).\\n\\nBATCH NOTE: the ingest-plan covers one or more source files. Each page's sources[] MUST cite only the source(s) that actually contributed content to THAT page — not all batch sources. The plan specifies which source(s) go with which page; follow it faithfully.\\n\\nSPEAKER RESOLUTION TABLES: When creating a sources/ page for a transcript that uses anonymous @N speaker handles (e.g. @1, @2, @3), include a SPEAKER_RESOLUTION_TABLE HTML comment block immediately after the call metadata section. One row per handle:\\n<!-- SPEAKER_RESOLUTION_TABLE\\n@N | Person Name | named|inferred|unresolved | brief basis\\nEND_SPEAKER_RESOLUTION_TABLE -->\\nStatus values: named = explicit name in transcript speaker label; inferred = identified by content-matching (conservative default for @N de-anonymization); unresolved = cannot reliably identify. Use 'inferred' even for high-confidence content matches — it is still inference, not confirmation.\\n\\nEnd with a non-empty one-line summary of what changed."
    ]

    // Step 4 — Verify the per-source write (deterministic). Route on exit code + sentinel.
    verify [
        shape=parallelogram,
        tool_command="bash .wiki/scripts/verify.sh >/tmp/wiki-verify.out 2>&1 && grep -q 'verify: clean' /tmp/wiki-verify.out && printf clean || printf dirty"
    ]
    verify_gate [shape=diamond]

    // Step 5 — RECONCILE the changed neighborhood (LLM, L3-scoped for speed): the
    // cross-ingest pass a human diff-review used to supply. Scoped to this ingest's
    // changed pages + same-type title check + inbound link-neighbors. TRADEOFF: catches
    // same-ingest conflicts; cross-ingest semantic consistency deferred to a full lint.
    // verify.sh is the whole-wiki structural safety net (dup-titles, orphans).
    reconcile [
        llm_provider="anthropic",
        prompt="MARKDOWN ENCODING RULE (non-negotiable): This wiki is plain UTF-8 markdown. When writing or editing ANY .md file, ALWAYS use actual Unicode characters and NEVER use JSON unicode escape sequences. Write — (em dash), not its JSON escape. Write \u201c and \u201d (curly quotes), not their JSON escapes. Write § (section sign), not its JSON escape. Write \u2019 (apostrophe), not its JSON escape. This rule applies even after reading flag-queue.json — JSON encoding is for .json files only, NEVER for .md files.\n\nReconcile only the neighborhood this ingest changed. verify.sh runs immediately after as the whole-wiki structural gate (it flags ALL duplicate titles and orphans across every page), so trust it as the global safety net. Your job is the semantic judgment verify.sh cannot make, scoped to what actually changed.\n\nDerive the changed-page set: run 'git status --short team-knowledge/' and collect the file paths (second field per line). Focus on entity pages in outcomes/, concepts/, people/, sources/ directories; backbone changes (overview.md, index.md) are secondary. If git status shows no changed entity pages, skip to step (4) and end with 'no reconciliation needed'.\n\n(1) SEMANTIC DUP RISK — new vs old: for each changed entity page, read its type and title from frontmatter. Then list ALL existing pages in the same entity-type directory (e.g. outcomes/ for an outcome page) and read their titles. If any existing page is semantically the same entity as a changed page under a different slug, MERGE: keep the richest/most-linked one, fold the other's unique content and sources[] in, repoint all [[wikilinks]] in the wiki to the canonical slug, delete the redundant file, fix index.md. Do not merge genuinely distinct entities.\n\n(2) INBOUND LINK NEIGHBORS: for each changed-page slug, search the wiki for pages that wikilink to it (search for [[ patterns containing the slug in team-knowledge/). Skim those neighbor pages for any loose cross-ref or dangling reference introduced by the new content. Fix real link-integrity issues only.\n\n(3) ORPHAN HEAL (changed pages only): if a changed entity page has zero inbound wikilinks from other pages, wire it in from a genuinely related page. Never fabricate relationships.\n\n(4) OPEN-QUESTIONS SCOPE EXPANSION — the semantic edge that wikilink-scope misses: read team-knowledge/open-questions.md. Collect every entity page named or [[wikilinked]] in the Tensions section (by slug or name). SETTLED-DOWNGRADE AUTHORITY (overriding rule — governs ALL settled pages in this section): for any page in this list that is currently status: settled, a downgrade to working is ONLY permitted when the tension text DIRECTLY CONTRADICTS or REVERSES that page\'s own `> **SETTLED:** ...` primary assertion — NOT merely because the entity is mentioned in the tension, NOT because adjacent/related entities in the same workstream appear there, NOT from body phrasing alone, NOT from weave-added cross-refs or new sections. When uncertain whether the tension truly contradicts the SETTLED assertion itself (vs touching a related topic), LEAVE IT SETTLED — do not invent a tension. For pages that are NOT status: settled (working/unsettled): if a tension marks them as still-open, aspirational, or undecided — OR the body\'s primary framing describes a direction rather than an established fact acted on today — downgrade to working and update index.md. Do NOT over-correct: only downgrade settled pages whose own primary SETTLED assertion is directly contested by a tension; genuinely settled facts stay settled.\n\n(5) Update index.md for any merges or status changes. Append a one-line reconciliation note to log.md.\n\nSETTLED-WRITE-LOCK GUARD: Before finishing, for each changed entity page, check its pre-ingest state: run 'git show HEAD:team-knowledge/<page> 2>/dev/null | head -5' to determine if the page was previously status: settled. CARVE-OUT (critical): This guard applies ONLY when the new source EXPLICITLY CONTRADICTS or REVERSES the page's `> **SETTLED:** ...` primary assertion. If the source AGREES with, RESTATES, CORROBORATES, or merely ADDS ADJACENT non-conflicting detail to the settled claim — or if the only changes to the page are new source citations, new sections, or weave-added wikilinks that do NOT reverse the SETTLED assertion — the guard does NOT apply: do NOT downgrade status, do NOT add a tension, leave `status: settled` intact. Only a direct contradiction of the SETTLED assertion triggers preserve+surface+downgrade. A page being merely *touched* or *expanded* is NOT a trigger. If a page WAS status: settled before this ingest and now shows changed primary claim content that CONTRADICTS the settled assertion or a changed status caused by genuine contradiction: (a) verify an explicit visible tension entry exists in open-questions.md recording both the old settled claim and the new contradicting claim (with source dates); (b) verify the page status is now working (not settled). If either check fails, DO NOT reaffirm settled status — add the missing tension entry to open-questions.md and ensure the page status is working. Never treat a later-dated source as automatic authority over a settled claim.\nEnd with a non-empty one-line summary ('no reconciliation needed' if nothing required)."
    ]

    // Step 6a — Provenance + status audit (LLM, L3-scoped for speed): audits only the
    // entity pages this ingest created or edited. TRADEOFF: cross-ingest status drift
    // (a later source contradicting an earlier settled page) is only caught by a full
    // lint pass, not here. verify.sh is the structural floor.
    provenance_audit [
        llm_provider="anthropic",
        prompt="MARKDOWN ENCODING RULE (non-negotiable): This wiki is plain UTF-8 markdown. When writing or editing ANY .md file, ALWAYS use actual Unicode characters and NEVER use JSON unicode escape sequences. Write — (em dash), not its JSON escape. Write \u201c and \u201d (curly quotes), not their JSON escapes. Write § (section sign), not its JSON escape. Write \u2019 (apostrophe), not its JSON escape. This rule applies even after reading flag-queue.json — JSON encoding is for .json files only, NEVER for .md files.\n\nAudit provenance + status honesty for ONLY the entity pages this ingest created or edited. Unchanged pages were each audited in their own ingest cycle — re-auditing them wastes time. Derive the changed-page set: run 'git status --short team-knowledge/' and collect the file paths. Focus on entity pages (outcomes/, concepts/, people/, sources/ directories). If the changed set has no entity pages, end with 'provenance: nothing to audit'.\n\nFor EACH changed entity page, RAW-AWARE:\n(1) Identify cited sources from sources[] frontmatter and any [[sources/...]] links. For each, open (a) team-knowledge/sources/<slug>.md and (b) the raw input it summarizes — the raw filename is noted on the source page's provenance line; find it in raw/ (current ingest) or raw/archive/ (prior ingests). If the raw file cannot be found, note it and treat raw as unavailable for that source.\n(2) For each load-bearing claim on the entity page, classify:\n   IN THE RAW BUT MISSING FROM THE SOURCE PAGE: not an over-claim — the summary is lossy. Heal the source page by adding the supporting detail from the raw input. Do NOT add a TODO-VERIFY to the entity page.\n   IN NEITHER the source page nor the raw: a true over-claim. Add '> TODO-VERIFY: <claim> — not found in cited source or raw input' right at that claim. If the page is status: settled, downgrade it to working (an analogy, forward projection, or still-maturing outcome should be 'working').\n   IN EITHER: fine, leave it.\n(3) Apply uniformly — quiet concept pages need the same rigor as spine outcomes.\n(4) Append a one-line note to log.md naming healed vs flagged counts.\n\n(STATUS RE-VALIDATION — scoped, load-bearing): SETTLED-DOWNGRADE AUTHORITY (single overriding rule — applied before all sub-conditions below): A page with `status: settled` may be downgraded to `working` ONLY when the CURRENT ingest\'s source material DIRECTLY CONTRADICTS or REVERSES that page\'s own `> **SETTLED:** ...` primary assertion. This is the ONLY trigger. NO other signal may independently downgrade a settled page — not an open-questions tension about adjacent/related entities, not body phrasing like \'focused on\' or \'working toward\', not weave-added cross-reference links, not a later-dated source that agrees. When uncertain whether the source truly contradicts the SETTLED assertion itself (vs touching a related topic), LEAVE IT SETTLED — do not invent a tension. Sub-conditions (1)–(3) below are SUBORDINATE to this rule: none of them may independently downgrade a settled page absent a direct contradiction of the SETTLED assertion. The schema contract is the anchor: settled = a decided bet / established fact the team is acting on right now; working = a live framing or active direction, not yet locked. For EACH changed entity page in outcomes/ or concepts/ that has status: settled (or that you are considering promoting to settled): sub-conditions (1)–(3) apply only when the SETTLED-DOWNGRADE AUTHORITY is satisfied. For pages that are NOT status: settled (working/unsettled), apply sub-conditions normally:\\n  (1) OPEN-QUESTIONS CHECK: read open-questions.md and check whether this entity (by name, title, or slug) appears in any tension listed there. For status: settled pages: the tension must DIRECTLY CONTEST that page\'s own SETTLED assertion — incidental mention of the entity, or a tension about adjacent/related entities in the same workstream, does NOT qualify. For non-settled pages: if the tension marks the entity as still-open, the page MUST be status: working.\\n  (2) PAGE-BODY SIGNAL: read the page's own body text. If the body's primary framing describes this as a direction the team is *heading toward* rather than an established fact the team is *acting on today* — signals include: "north-star", "destination", "heading toward", "the future the team is heading", "new frontier", "aspiration", "not yet a shipped/owned/fully-specified bet", or the entity describes a future state with no owning project or product — for non-settled pages (working/unsettled) the page MUST be status: working. IMPORTANT: these body signals do NOT independently downgrade a page that is already status: settled — see SETTLED-DOWNGRADE AUTHORITY above. A settled page whose body says \'working toward\' or \'heading toward\' is NOT automatically downgraded; only a direct contradiction of its own SETTLED assertion triggers downgrade.\\n(3) OPEN-QUESTIONS SCOPE EXPANSION — the cross-ingest semantic edge: even for entity pages NOT in this ingest\'s git-status changed set, if the entity (by name, title, or slug) is referenced in a tension in team-knowledge/open-questions.md, read that tension AND the entity page. For status: settled pages: the tension must DIRECTLY CONTEST that page\'s own SETTLED assertion; mere mention of the entity in a tension about adjacent entities does NOT downgrade a settled page — see SETTLED-DOWNGRADE AUTHORITY above. For non-settled pages: if the tension indicates the entity is still open, aspirational, or undecided — the page MUST be status: working. This catches the case where a later ingest writes an open-questions tension naming an earlier settled page (that page falls outside changed-page scope but is now named as unresolved in open-questions); but ONLY if the tension contests the SETTLED assertion itself, not merely references the entity.\\\\nDo NOT over-correct: only apply this to pages that are named in a tension that specifically flags them as open; genuinely settled bets the team acts on today stay settled.\nDo NOT over-correct on conditions (1)–(3): core bets they are executing against today (e.g. compounding-stack, disruption-from-within, commodity-thesis) stay settled even if mentioned in passing in open-questions. Judge the *primary framing* of the tension, not incidental mentions. Downgrade if any condition holds; never promote a page to settled if any condition fires.\n\n(CROSS-SOURCE CONTRADICTION CHECK — bounded): for each entity page created or touched by this ingest, check its cited sources[] against other source pages already in team-knowledge/sources/ that also reference the same entity (search for [[entity-slug]] or entity name in other source pages). If two sources make contradictory claims about the same entity — e.g. one frames it as a durable moat and another as table-stakes, one frames it as settled and another as open — add a real entry to the \'## Contradictions surfaced\' section of open-questions.md. Replace the HTML comment placeholder if it is the only content. Each entry: the two claims, their source slugs, a plain-English statement of the conflict, and that human adjudication is needed. This is bounded by the entities the new source discusses, NOT a full re-read of every page. If no contradictions are found, leave open-questions.md unchanged.\n\nSETTLED-WRITE-LOCK GUARD: For each changed entity page, check its pre-ingest status: run 'git show HEAD:team-knowledge/<page> 2>/dev/null | grep "^status:"' to see the status before this ingest. CARVE-OUT (critical): This guard applies ONLY when the new source EXPLICITLY CONTRADICTS or REVERSES the page's `> **SETTLED:** ...` primary assertion. If the source AGREES with, RESTATES, CORROBORATES, or merely ADDS ADJACENT non-conflicting detail to the settled claim — or if the only changes to the page are new source citations, new sections, or weave-added wikilinks that do NOT reverse the SETTLED assertion — the guard does NOT apply: do NOT downgrade status, do NOT add a tension, leave `status: settled` intact. Only a direct contradiction of the SETTLED assertion triggers preserve+surface+downgrade. A page being merely *touched* or *expanded* is NOT a trigger. If a page was previously status: settled and now shows changed primary claim content that EXPLICITLY CONTRADICTS the settled assertion, DO NOT confirm or write 'settled status confirmed correct'. Instead verify: (1) a visible tension entry is present in open-questions.md recording both the old settled claim and the new contradicting claim with source dates; (2) the page status is working (not settled). If either is missing, add the tension entry and set the page status to working. NEVER write that a settled claim was 'superseded' by a newer source and auto-resolve the conflict — that is the exact faithfulness failure this guard prevents. Settled contradictions MUST surface as tensions, not auto-resolutions.\nEnd with a non-empty one-line summary."
    ]

    // Step 6b — Enforce speaker attribution (DETERMINISTIC script, 0% LLM).
    // Parses SPEAKER_RESOLUTION_TABLE structured blocks from source pages (falls
    // back to parsing existing prose for old pages and backfills the block).
    // For each people/ page citing a source with an inferred @N handle, guarantees
    // an ## Attribution confidence section is present. Idempotent.
    // Replaces the LLM ATTRIBUTION-CONFIDENCE CHECK that was proven unreliable
    // (33% per-trial hit rate in the A/B eval; removed from all prompts).
    enforce_attribution [
        shape=parallelogram,
        tool_command="python3 .wiki/scripts/enforce_speaker_attribution.py team-knowledge && printf enforced || printf enforced"
    ]

    // Step 7 — WEAVE the connections layer (LLM, scoped outward from seeds): the Memex
    // associative-trail phase. Generates NEW grounded associative trails between DISTINCT,
    // already-correct entity pages — connections no source stated but genuinely implied by
    // claims already on the pages. ADDS connections only; never deletes, never touches status.
    // Spike-proven: 8/10 grounded non-obvious connections, 0 hallucinations on real 33-page wiki.
    // Weave ≠ reconcile: reconcile resolves/merges/deduplicates; weave generates new trails.
    weave [
        llm_provider="anthropic",
        prompt="MARKDOWN ENCODING RULE (non-negotiable): This wiki is plain UTF-8 markdown. When writing or editing ANY .md file, ALWAYS use actual Unicode characters and NEVER use JSON unicode escape sequences. Write \u2014 (em dash), not its JSON escape. Write \\u201c and \\u201d (curly quotes), not their JSON escapes. Write \u00a7 (section sign), not its JSON escape. Write \\u2019 (apostrophe), not its JSON escape. This rule applies even after reading flag-queue.json \u2014 JSON encoding is for .json files only, NEVER for .md files.\n\nYou are the WEAVE stage of the ingest pipeline. Your job is to GENERATE new grounded associative trails between DISTINCT, already-correct entity pages \u2014 connections no source document stated but that are genuinely implied by claims already on the pages. You ADD connections only; you do NOT delete content, reorder pages, or change status fields (reconcile and provenance_audit handle those).\n\nSCOPE: Run 'git status --short team-knowledge/' and collect the changed entity-page paths (outcomes/, concepts/, people/, sources/ dirs). These are your SEED pages. Read each seed page plus index.md. Identify CANDIDATE pages from the catalog \u2014 existing pages whose one-liner suggests a possible relationship to the seed content. Read only the seeds and your candidates (\u226410 pages total). Do NOT re-read the whole wiki.\n\nIf no entity pages changed (only backbone pages in git status), end immediately with: 'weave: no entity seeds \u2014 no connections generated.'\n\nTARGET \u2014 3 HIGH-VALUE PATTERNS ONLY (these produce grounded results; generic 'connections' do not):\n(1) STRENGTH-AS-CONSTRAINT REFRAMES: seed page A asserts a strength or capability; candidate page B reveals that same strength is gated, capped, or conditional. The connection: A's strength holds unless/until B's condition applies.\n(2) CROSS-PAGE TENSIONS: seed page A and candidate page B seem to pull in opposite directions. Record the synthesis discipline that holds both \u2014 not a verdict, not a contradiction to resolve.\n(3) PERSON<->CONCEPT DUALITIES: a person page's lived framing IS the concrete definition or most grounded operational example of an abstract concept page, or mirrors it.\n\nFor each candidate connection, apply BOTH gates before recording:\n\nGATE 1 \u2014 GROUNDING: State the relationship using ONLY claims already on page A AND claims already on page B, each already source-traced. If the connection requires any fact NOT already on either page \u2014 it is FABRICATION \u2014 DROP IT. Connections get NO new sources[] entries.\n\nGATE 2 \u2014 VALUE: Would a careful reader who had already read BOTH pages individually see this connection? If yes \u2014 TRIVIAL \u2014 skip it. Record only what neither page makes obvious alone.\n\nMECHANICAL DEDUP (non-optional \u2014 do NOT rely on recall): Before recording any connection as new, use your search/grep tool to check whether the two pages already link to each other. Search page-A's content for page-B's slug, and search page-B's content for page-A's slug. If EITHER already references the other in any [[wikilink]], the connection is ALREADY RECORDED \u2014 skip it entirely.\n\nRECORDING \u2014 use the cheapest form that fits:\n- INLINE WIKILINK: if natural prose on the page already touches the connected concept, add a [[wikilink]] inline where it fits.\n- SEE-ALSO NOTE (the default form): add a '## See also' section (or append to an existing one) with one sentence explaining WHY this connection matters. BIDIRECTIONAL \u2014 add the reciprocal note on the other page too.\n- SYNTHESIS PAGE (rare, highest fabrication risk): ONLY if the SAME cross-cutting relationship recurs across >=2 grounded page pairs AND deserves a named concept of its own. If created: status: working (NEVER settled), [[wikilink]] back to the pages it ties, add a note in open-questions.md marking it speculative. When unsure, prefer a See-also note.\n- Do NOT update overview.md here — the update_spine node owns the spine. Focus solely on cross-entity wikilink connections between entity pages.\n\nAPPEND to log.md one line: '## [YYYY-MM-DD] weave | +N connections (M see-also, K synthesis pages)' or 'weave: no grounded connections found.'\n\n\n\nINFERRED-SPEAKER ATTRIBUTION: When writing a person⇔concept connection where the claim attribution traces through an @N handle marked as 'inferred' in the source's SPEAKER_RESOLUTION_TABLE (or prose resolution section), append the marker `(speaker attribution inferred — @N in [[sources/<slug>]])` immediately after the attributed claim in the See also note. Never present an inferred-speaker attribution as a definitive settled fact.\n\nEnd with a non-empty one-line summary of what you found and recorded."
    ]


    // Step 7b — UPDATE_SPINE: mandatory narrative-spine maintenance (LLM, sonnet).
    // Runs after weave so it sees the final entity-page state. MANDATORY every run —
    // no conditional, no skip on large batches. Owns overview.md and open-questions.md.
    // RATIONALE: weave is saturated at N>=5 and consistently judges nothing clears the
    // "materially changes" bar, producing a byte-identical spine. This node removes that
    // conditional entirely; its prompt requires spine integration on every execution.
    update_spine [
        llm_provider="anthropic",
        prompt="MARKDOWN ENCODING RULE (non-negotiable): This wiki is plain UTF-8 markdown. When writing or editing ANY .md file, ALWAYS use actual Unicode characters and NEVER use JSON unicode escape sequences. Write — (em dash), not its JSON escape. Write \u201c and \u201d (curly quotes), not their JSON escapes. Write § (section sign), not its JSON escape. Write \u2019 (apostrophe), not its JSON escape. This rule applies even after reading flag-queue.json — JSON encoding is for .json files only, NEVER for .md files.\n\nYou are the UPDATE_SPINE stage of the ingest pipeline. This is a MANDATORY step — you MUST update overview.md and sweep open-questions.md on every single ingest run, regardless of batch size or content volume. There is NO conditional: skipping is not allowed.\n\n(1) IDENTIFY THIS CYCLE'S CHANGES: Run 'git diff --name-only HEAD team-knowledge/' to list entity pages created or changed this cycle. Also read .wiki/ingest-plan.md for the full ingest plan. Together these tell you what new entities, decisions, and storylines were added this cycle.\n\n(2) READ THE CURRENT SPINE: Read team-knowledge/overview.md in full.\n\n(3) UPDATE overview.md — MANDATORY, NO EXCEPTIONS: overview.md is the wiki's narrative spine — the single-story summary of what the team is doing and why. You MUST integrate this cycle's new material. Rules: (a) DO NOT rewrite from scratch. DO NOT destroy or replace existing narrative. Integrate and extend. (b) DO NOT copy-paste raw source text. Synthesize: what does this material add to the story of what the team is doing? (c) Weave new entities, decisions, and storylines into the existing prose naturally. (d) If — after genuinely reviewing the changed pages — the new material truly adds nothing to the top-level narrative (e.g., purely internal structural corrections with no new storyline), you MUST still: bump the `updated:` frontmatter date to today AND append a brief parenthetical at the end of overview.md noting what was ingested and why it did not change the narrative. (e) Keep overview.md concise. It is a spine, not a dump. Integrate; do not append block-quoted summaries.\n\n(4) SWEEP open-questions.md — MANDATORY: Read team-knowledge/open-questions.md. Add any NEW open questions, tensions, or cross-source contradictions this cycle raised. Annotate or resolve any previously-open questions now answered by this cycle's sources. Bump the `updated:` frontmatter date if you changed anything.\n\n(5) Append to log.md one line: 'update_spine: overview.md updated — <one-line reason>; open-questions: <N added, M resolved>'\n\nEnd with a non-empty one-line summary of what you integrated into the spine and what open questions changed."
    ]

    // Step 8 — Second reviewer (LLM, L3-scoped for speed): automated adjudication BEFORE
    // any human, fully non-blocking. Scoped to TODO-VERIFY flags on the changed pages only
    // — prior ingests' flags are already in flag-queue.json. Preserves existing entries.
    review [
        llm_provider="anthropic",
        prompt="MARKDOWN ENCODING RULE (non-negotiable): This wiki is plain UTF-8 markdown. When writing or editing ANY .md file, ALWAYS use actual Unicode characters and NEVER use JSON unicode escape sequences. Write — (em dash), not its JSON escape. Write \u201c and \u201d (curly quotes), not their JSON escapes. Write § (section sign), not its JSON escape. Write \u2019 (apostrophe), not its JSON escape. This rule applies even after reading flag-queue.json — JSON encoding is for .json files only, NEVER for .md files.\n\nYou are the independent second reviewer. Work ONLY from files on disk. Derive the changed-page set: run 'git status --short team-knowledge/' and collect the file paths (entity pages only). Find TODO-VERIFY flags ONLY on those changed pages — prior ingests' flags are already in flag-queue.json and do NOT need re-processing.\n\nFor EACH TODO-VERIFY flag found on a changed page:\n(1) Open the page, its cited source page (team-knowledge/sources/<slug>.md), and the raw input (raw/ or raw/archive/). Decide:\n   CONFIRM: the claim genuinely lacks support in both the source page and the raw — KEEP the TODO-VERIFY line.\n   CORRECT: the claim IS supported by the source page or the raw — REMOVE that '> TODO-VERIFY:' line from the page. Note why.\n   UNCERTAIN: inconclusive from the files alone — KEEP the flag and record for human.\n\n(2) Read the existing team-knowledge/flag-queue.json (use [] if absent or invalid). Preserve ALL existing entries unchanged (they belong to prior ingests). Add or update entries ONLY for this ingest's changed-page flags that remain after your CORRECT removals. Write the merged array as valid JSON to team-knowledge/flag-queue.json. Each new entry: {\"page\": \"<path under team-knowledge/>\", \"claim\": \"<flagged claim text>\", \"cited_source\": \"<source slug>\", \"raw_source\": \"<raw filename or null>\", \"reviewer_note\": \"<why human review needed>\", \"status\": \"open\"}.\n\n(3) Append to log.md: 'review: confirmed X, corrected Y over-cautious flags, queued Z for human'.\nEnd with a non-empty one-line summary naming X, Y, Z."
    ]

    // Step 9 — Verify again under the hardened gate (catches dup-titles + orphans).
    verify2 [
        shape=parallelogram,
        tool_command="bash .wiki/scripts/verify.sh >/tmp/wiki-verify2.out 2>&1 && grep -q 'verify: clean' /tmp/wiki-verify2.out && printf clean || printf dirty"
    ]
    verify2_gate [shape=diamond]

    // Step 10 — Archive the ingested source (deterministic).
    archive [
        shape=parallelogram,
        tool_command="mkdir -p raw/archive && ARCHIVED=0; for f in raw/*.md raw/*.txt raw/*.rst; do [ -f \"$f\" ] && mv \"$f\" raw/archive/ && ARCHIVED=$((ARCHIVED+1)); done; printf 'archived %d file(s)' $ARCHIVED"
    ]

    start -> orient
    orient -> classify    [condition="context.tool.last_line=ready"]
    orient -> done        [condition="context.tool.last_line=uninitialized"]
    classify -> classify_gate
    classify_gate -> mine [condition="context.tool.last_line=CLASSIFY_OK", weight=10]
    classify_gate -> done [condition="context.tool.last_line=CLASSIFY_REJECTED", weight=1]
    mine -> write_pages
    write_pages -> verify
    verify -> verify_gate
    verify_gate -> reconcile   [condition="context.tool.last_line=clean", weight=10]
    verify_gate -> write_pages [condition="context.tool.last_line=dirty", weight=5]
    reconcile -> provenance_audit
    provenance_audit -> enforce_attribution
    enforce_attribution -> weave
    weave -> update_spine
    update_spine -> review
    review -> verify2
    verify2 -> verify2_gate
    verify2_gate -> archive    [condition="context.tool.last_line=clean", weight=10]
    verify2_gate -> reconcile  [condition="context.tool.last_line=dirty", weight=5]
    archive -> done
}
