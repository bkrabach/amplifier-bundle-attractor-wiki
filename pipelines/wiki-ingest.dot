// wiki-ingest pipeline — the attractor re-expression of /wiki-ingest.
//
// Runs under the wiki-agent-anthropic child profile (attractor tools + llm-wiki
// orientation composed in). The LOAD-BEARING schema/scripts are project-side in
// .wiki/ and reached by the box nodes' filesystem tools (proven in seam-1); the
// orientation "why" lens is composed into the agent (proven in seam-2).
//
// Node-type discipline (attractor conventions):
//   parallelogram = deterministic shell (route on EXIT CODE, never LLM text)
//   box (default) = LLM agent node (judgment / content generation)
//   diamond       = pure router
//
// STATUS: write→verify loop PROVEN green end-to-end (mines a source, writes
// interlinked pages, passes verify.sh). This revision adds a RECONCILE pass
// (whole-wiki dedup-merge + orphan-heal) gated by the HARDENED verify.sh, to
// close the A/B finding: headless single-source ingest filed the same entity
// twice across runs (aios.md + agentic-os.md, one orphaned) because nothing did
// the cross-ingest reconciliation a human diff-review supplies.

digraph WikiIngest {
    graph [
        goal="Ingest the source named in $source into the wiki per .wiki/context/schema.md",
        default_max_retry=3,
        default_fidelity="full",
        default_thread_id="wiki-ingest"
    ]

    start [shape=Mdiamond]
    done  [shape=Msquare]

    // Step 1 — Orient (deterministic): is the project initialized + is there a source?
    orient [
        shape=parallelogram,
        tool_command="test -f .wiki/context/schema.md && ls raw/ >/dev/null 2>&1 && printf ready || printf uninitialized"
    ]

    // Step 2 — Mine the source (LLM): extract per schema, write a concrete ingest plan.
    mine [
        llm_provider="anthropic",
        prompt="You are running /wiki-ingest as an automated pipeline (no interactive mode, no human in the loop). The load-bearing contract is .wiki/context/schema.md; your mounted orientation explains the pattern to read it through. Read raw/$source, mine it per the schema (entities, concepts, decisions, cross-refs), and WRITE a concrete ingest plan to .wiki/ingest-plan.md naming every page to create or update with the specific edits and the source citations. IMPORTANT: first read the EXISTING pages under team-knowledge/ (outcomes, concepts, people, sources) and reuse an existing entity page when the source refers to the same thing under a different name — do not invent a new slug for an entity that already exists. Do not write wiki pages yet. End with a one-line summary; your final message MUST be non-empty plain text."
    ]

    // Step 3 — Apply the plan (LLM): create/edit pages, update index + log, cite.
    // No goal_gate: the deterministic verify.sh loop below IS the real gate.
    write_pages [
        llm_provider="anthropic",
        prompt="Apply .wiki/ingest-plan.md against the wiki package: create/edit each page following the schema's frontmatter + body conventions, wire [[wikilinks]] and sources[], update index.md, and append one line to log.md. Cite every claim to a source page. Honor the status discipline (settled / working / unsettled; proposals are NOT decisions; never fabricate). End with a non-empty one-line summary of what changed."
    ]

    // Step 4 — Verify the per-source write (deterministic). Route on exit code + sentinel.
    verify [
        shape=parallelogram,
        tool_command="bash .wiki/scripts/verify.sh >/tmp/wiki-verify.out 2>&1 && grep -q 'verify: clean' /tmp/wiki-verify.out && printf clean || printf dirty"
    ]
    verify_gate [shape=diamond]

    // Step 5 — RECONCILE the WHOLE wiki (LLM): the cross-ingest pass a human diff-review
    // used to supply. Merge duplicate entities, heal orphans, keep the spine coherent.
    reconcile [
        llm_provider="anthropic",
        prompt="Reconcile the ENTIRE wiki (not just this source's pages) so it stays a single coherent knowledge base across ingests. Do ALL of:\n(1) DUPLICATES: find entity pages that are the same thing under different slugs OR share a title (e.g. an 'AIOS' page and an 'Agentic OS' page). MERGE each set into ONE canonical page — keep the richest / most-linked one, fold in the other's unique content and sources[], REPOINT every [[wikilink]] in the wiki to the canonical slug, DELETE the redundant file, and fix index.md.\n(2) ORPHANS: find entity pages with no inbound [[wikilink]] from any other page. Wire each into the spine with a real [[wikilink]] from a genuinely related page (or, if it is truly redundant, merge it away). Do not fabricate relationships.\n(3) Update index.md and append a one-line reconciliation note to log.md.\nThe hardened .wiki/scripts/verify.sh now FAILS on duplicate titles and on orphan entity pages, so leave NONE. End with a non-empty one-line summary of merges/heals (or 'no reconciliation needed')."
    ]

    // Step 6 — Provenance + status audit (LLM): the SEMANTIC check verify.sh CANNOT be.
    // The independent A/B panel converged on one miss — the pipeline over-claims:
    // it stamps 'settled' on still-evolving entities and asserts specifics its cited
    // sources don't actually carry (the human reviewer's doubt, deleted). This node
    // restores that doubt: downgrade unsupported 'settled' claims, never promote.
    provenance_audit [
        llm_provider="anthropic",
        prompt="Audit the WHOLE wiki for provenance + status honesty — the judgment a human reviewer supplies, which no script can. For EVERY entity page, audited UNIFORMLY (the same rigor on a quiet concept page as on the spine outcomes — the prior panel found unflagged claims hiding on low-traffic pages):\n(1) Open the source pages it cites (sources[] frontmatter + any [[sources/...]] links) and READ them.\n(2) For each load-bearing claim on the page, confirm the cited sources actually contain it. The schema rule: every claim traces to a source, and status is LOAD-BEARING — settled = locked/verified, working = live/still-evolving, unsettled = open.\n(3) Flag EVERY unsupported specific on EVERY entity page regardless of status: wherever a page (settled OR working, high-traffic OR obscure) asserts a claim its cited sources do NOT contain, add a line '> TODO-VERIFY: <claim> — not found in cited sources' right at that claim. Apply this UNIFORMLY — do not let quiet pages off the hook. ADDITIONALLY, if such a page is status: settled, DOWNGRADE it to working (an analogy, a forward-looking projection, or a still-maturing outcome should be 'working', not 'settled'); or move a genuinely-open assertion into open-questions.md.\n(4) Be conservative and surgical: only downgrade/flag claims that genuinely lack source support; do NOT delete real content, do NOT invent doubt where the source backs the claim, and NEVER promote anything upward.\n(5) Append a one-line note to log.md naming what you downgraded/flagged (or 'provenance: all settled claims trace to cited sources').\nEnd with a non-empty one-line summary."
    ]

    // Step 7 — Verify again under the hardened gate (catches dup-titles + orphans).
    verify2 [
        shape=parallelogram,
        tool_command="bash .wiki/scripts/verify.sh >/tmp/wiki-verify2.out 2>&1 && grep -q 'verify: clean' /tmp/wiki-verify2.out && printf clean || printf dirty"
    ]
    verify2_gate [shape=diamond]

    // Step 7 — Archive the ingested source (deterministic).
    archive [
        shape=parallelogram,
        tool_command="mkdir -p raw/archive && mv raw/$source raw/archive/ && printf archived"
    ]

    start -> orient
    orient -> mine        [condition="context.tool.last_line=ready"]
    orient -> done        [condition="context.tool.last_line=uninitialized"]
    mine -> write_pages
    write_pages -> verify
    verify -> verify_gate
    verify_gate -> reconcile   [condition="context.tool.last_line=clean", weight=10]
    verify_gate -> write_pages [condition="context.tool.last_line=dirty", weight=5]
    reconcile -> provenance_audit
    provenance_audit -> verify2
    verify2 -> verify2_gate
    verify2_gate -> archive    [condition="context.tool.last_line=clean", weight=10]
    verify2_gate -> reconcile  [condition="context.tool.last_line=dirty", weight=5]
    archive -> done
}
